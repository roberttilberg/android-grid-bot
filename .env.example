# Example .env file for android-grid-bot
# Copy this to ~/.env and fill values.
#
# Recommended rollout order:
# 1) Mock mode (no exchange account): EXCHANGE_ID=mock, EXECUTE_LIVE=false
# 2) Testnet with execution off: EXCHANGE_TESTNET=true, EXECUTE_LIVE=false
# 3) Testnet with execution on: EXCHANGE_TESTNET=true, EXECUTE_LIVE=true
# 4) Mainnet canary: EXECUTE_LIVE=true, EXCHANGE_TESTNET=false,
#    ALLOW_MAINNET_LIVE=true, LIVE_ACCOUNT_ISOLATED=true

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange credentials (examples)
PHEMEX_API_KEY=
PHEMEX_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Generic fallback names (some scripts look for these)
API_KEY=
API_SECRET=

# LLM / external services
GROQ_API_KEY=

# Safety baseline: keep false until each rollout stage is validated.
EXECUTE_LIVE=false

# Exchange runtime mode
EXCHANGE_ID=binance
EXCHANGE_TESTNET=true
EXCHANGE_MARKET_TYPE=spot
SYMBOL=XRP/USDT

# Optional local API-lifecycle testing mode (no real exchange):
# EXCHANGE_ID=mock

# Mainnet live safety gates (required when EXECUTE_LIVE=true and EXCHANGE_TESTNET=false)
ALLOW_MAINNET_LIVE=false
LIVE_ACCOUNT_ISOLATED=false

# Short trading controls (disabled by default)
ALLOW_SHORTS=false
# Valid values: futures | margin
SHORT_MODE=futures
MAX_SHORT_ZONES=3
# Total short exposure cap in quote currency (USDT)
MAX_SHORT_NOTIONAL=50
# Emergency close trigger when estimated margin ratio falls below this value
MIN_MARGIN_RATIO=1.5
# Additional explicit gate for mainnet shorting
ALLOW_MAINNET_SHORTS=false
