# Example .env file for android-grid-bot
# Copy this to ~/.env and fill values. Keep live-execution disabled by default.

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange credentials (examples)
PHEMEX_API_KEY=
PHEMEX_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Generic fallback names (some scripts look for these)
API_KEY=
API_SECRET=

# LLM / external services
GROQ_API_KEY=

# Safety: default to false. Must set to true locally and explicitly authorize before live execution.
EXECUTE_LIVE=false
